{
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/bomb", "destination": "/bomb.html" },
    { "source": "/attend", "destination": "/attend.html" },
    { "source": "/attend/(.*)", "destination": "/attend.html" },
    { "source": "/parents", "destination": "/parents.html" },
    { "source": "/parents/(.*)", "destination": "/parents.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(index|attend|parents|bomb).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
